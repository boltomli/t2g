## Game Generator - 游戏生成器
extends Node
class_name GameGenerator

## 信号
signal game_generated(project_path: String)
signal generation_progress(step: String, progress: float)
signal generation_failed(error: String)

## 引用
var llm_client: LLMClient

## 生成配置
var output_dir: String = "user://generated_games/"

func _ready() -> void:
	llm_client = LLMClient.new()
	add_child(llm_client)
	llm_client.response_received.connect(_on_llm_response)
	llm_client.error_occurred.connect(_on_llm_error)

## 生成完整游戏
func generate_game(text: String, analysis: Dictionary, game_type: String, game_config: Dictionary) -> void:
	var game_name = game_config.get("game_info", {}).get("title", "generated_game")
	var project_path = output_dir + game_name
	
	# 创建目录结构
	_create_project_structure(project_path)
	
	generation_progress.emit("创建项目配置", 0.1)
	_create_project_godot(project_path, game_config)
	
	generation_progress.emit("生成主场景", 0.2)
	_create_main_scene(project_path, game_config, game_type)
	
	generation_progress.emit("生成主脚本", 0.25)
	_create_main_script(project_path, game_config, game_type)
	
	generation_progress.emit("生成角色系统", 0.3)
	_create_character_system(project_path, game_config)
	
	generation_progress.emit("生成对话系统", 0.4)
	_create_dialogue_system(project_path, game_config)
	
	generation_progress.emit("生成游戏场景", 0.5)
	_create_game_scene(project_path, game_config, game_type)
	
	generation_progress.emit("生成游戏场景脚本", 0.55)
	_create_game_scene_script(project_path, game_config, game_type)
	
	generation_progress.emit("生成额外场景", 0.6)
	_create_game_scenes(project_path, game_config, game_type)
	
	generation_progress.emit("生成UI系统", 0.65)
	_create_ui_system(project_path, game_config)
	
	generation_progress.emit("生成游戏逻辑", 0.7)
	_create_game_logic(project_path, game_config, game_type)
	
	generation_progress.emit("生成资源文件", 0.8)
	_create_resources(project_path, game_config)
	
	generation_progress.emit("保存游戏数据", 0.9)
	_save_game_data(project_path, text, analysis, game_config)
	
	generation_progress.emit("完成", 1.0)
	game_generated.emit(project_path)

## 创建项目目录结构
func _create_project_structure(project_path: String) -> void:
	var dirs = [
		"",
		"scenes",
		"scripts",
		"resources",
		"resources/fonts",
		"resources/images",
		"resources/music",
		"resources/sounds",
		"data"
	]
	
	for dir in dirs:
		var full_path = project_path + "/" + dir
		DirAccess.make_dir_recursive_absolute(full_path)

