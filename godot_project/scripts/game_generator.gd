## 创建UI系统
func _create_ui_system(project_path: String, config: Dictionary) -> void:
	var ui_script = """## UI系统
extends CanvasLayer

## 信号
signal button_pressed(button_name: String)

## UI元素引用
@onready var dialogue_box = $DialogueBox
@onready var name_label = $DialogueBox/VBox/NameLabel
@onready var text_label = $DialogueBox/VBox/TextLabel
@onready var choices_container = $DialogueBox/VBox/ChoicesContainer

func _ready() -> void:
	_hide_dialogue()

func show_dialogue(speaker: String, text: String, choices: Array = []) -> void:
	dialogue_box.visible = true
	name_label.text = speaker
	text_label.text = text
	
	# 清除旧选项
	for child in choices_container.get_children():
		child.queue_free()
	
	# 添加新选项
	for i in range(choices.size()):
		var button = Button.new()
		button.text = choices[i]
		button.pressed.connect(_on_choice_pressed.bind(i))
		choices_container.add_child(button)

func _hide_dialogue() -> void:
	dialogue_box.visible = false

func _on_choice_pressed(index: int) -> void:
	button_pressed.emit("choice_" + str(index))
	_hide_dialogue()

func show_notification(text: String, duration: float = 2.0) -> void:
	# 显示通知
	pass
"""
	_save_file(project_path + "/scripts/ui_system.gd", ui_script)

## 创建游戏逻辑
func _create_game_logic(project_path: String, config: Dictionary, game_type: String) -> void:
	var game_logic = """## 游戏逻辑管理器
extends Node

## 信号
signal game_state_changed(state: String)
signal scene_changed(scene_name: String)

## 游戏状态
var current_scene: String = "main"
var game_data: Dictionary = {}
var player_data: Dictionary = {
	"name": "玩家",
	"level": 1,
	"experience": 0,
	"inventory": [],
	"stats": {
		"strength": 10,
		"dexterity": 10,
		"intelligence": 10
	}
}

func _ready() -> void:
	_load_game_data()

func _load_game_data() -> void:
	# 加载游戏配置数据
	var file = FileAccess.open("user://data/game_config.json", FileAccess.READ)
	if file:
		var json = JSON.new()
		var result = json.parse(file.get_as_text())
		if result == OK:
			game_data = json.data
		file.close()

func change_scene(scene_name: String) -> void:
	current_scene = scene_name
	scene_changed.emit(scene_name)
	get_tree().change_scene_to_file("res://scenes/%s.tscn" % scene_name)

func add_experience(amount: int) -> void:
	player_data["experience"] += amount
	# 检查升级
	var needed_exp = player_data["level"] * 100
	if player_data["experience"] >= needed_exp:
		player_data["level"] += 1
		player_data["experience"] -= needed_exp
		game_state_changed.emit("level_up")

func add_item(item: Dictionary) -> void:
	player_data["inventory"].append(item)

func has_item(item_name: String) -> bool:
	for item in player_data["inventory"]:
		if item.get("name") == item_name:
			return true
	return false

func save_game() -> void:
	var file = FileAccess.open("user://save_game.json", FileAccess.WRITE)
	if file:
		file.store_string(JSON.stringify(player_data, "\t"))
		file.close()

func load_game() -> void:
	var file = FileAccess.open("user://save_game.json", FileAccess.READ)
	if file:
		var json = JSON.new()
		var result = json.parse(file.get_as_text())
		if result == OK:
			player_data = json.data
		file.close()
"""
	_save_file(project_path + "/scripts/game_logic.gd", game_logic)

