# Text2Game 配置文件
# 复制此文件为 .env 并修改配置

# LLM API 配置
LLM_API_URL=http://localhost:1234/v1
LLM_MODEL=google/gemma-4-12b-qat
# API密钥（可选，某些服务器可能需要）
LLM_API_KEY=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=16384

# 超时和重试配置
LLM_TIMEOUT=180
LLM_MAX_RETRIES=3

# 文本处理配置
CHUNK_SIZE=8000

# Reasoning 配置
ENABLE_REASONING=false
